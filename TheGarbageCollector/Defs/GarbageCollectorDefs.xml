<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- HUD Alert dynamically registered by C# (inheriting from RimWorld.Alert) -->

  <!-- 2. Incident Definition -->
  <IncidentDef>
    <defName>Incident_SummonGarbageCollector</defName>
    <label>summon garbage collector</label>
    <category>Special</category>
    <targetTags>
      <li>Map_PlayerHome</li>
    </targetTags>
    <workerClass>TheGarbageCollector.IncidentWorker_SummonGarbageCollector</workerClass>
    <baseChance>0</baseChance>
    <minRefireDays>1</minRefireDays>
    <pointsScaleable>false</pointsScaleable>
  </IncidentDef>

  <!-- 3. AI Duty Definition -->
  <DutyDef>
    <defName>GarbageCollectorDuty</defName>
    <thinkNode Class="ThinkNode_Priority">
      <subNodes>
        <li Class="TheGarbageCollector.JobGiver_GarbageCollectorAuraClean" />
        <li Class="JobGiver_ExitMapBest">
          <defaultLocomotion>Walk</defaultLocomotion>
        </li>
      </subNodes>
    </thinkNode>
  </DutyDef>

  <!-- 4. Gear Hediff Definition -->
  <HediffDef>
    <defName>GarbageCollectorGear</defName>
    <label>hazard protection suit</label>
    <description>A specialized hazmat suit providing enhanced movement speed and complete toxic resistance.</description>
    <hediffClass>TheGarbageCollector.Hediff_GarbageCollectorGear</hediffClass>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>5.0</MoveSpeed> <!-- Strong offset to guarantee 2.0x base speed -->
          <ToxicResistance>1.0</ToxicResistance>
          <ToxicEnvironmentResistance>1.0</ToxicEnvironmentResistance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <!-- 5. Custom Pawn Kind -->
  <PawnKindDef ParentName="OutlanderBase">
    <defName>GarbageCollector</defName>
    <label>garbage collector</label>
    <race>Human</race>
    <combatPower>40</combatPower>
    <chemicalAddictionChance>0</chemicalAddictionChance>
    <initialResistanceRange>10~20</initialResistanceRange>
    <initialWillRange>1~3</initialWillRange>
    <apparelRequired>
      <li>Apparel_PowerArmorHelmet</li>
      <li>Apparel_PowerArmor</li>
    </apparelRequired>
    <apparelColor>(0.98, 0.75, 0.0)</apparelColor> <!-- Bright hazard yellow -->
  </PawnKindDef>

</Defs>
