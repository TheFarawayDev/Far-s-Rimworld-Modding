<?xml version="1.0" encoding="utf-8"?>
<ModMetaData>
  <name>Blighted Alert</name>
  <author>TheFarawayDev</author>
  <packageId>thefarawaydev.blightedalert</packageId>
  <supportedVersions>
    <li>1.6</li>
