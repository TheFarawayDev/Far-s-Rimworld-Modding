<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ===== Stone chunk recipes (all 3 quarry sizes) ===== -->

  <RecipeDef>
    <defName>Quarry_ChunkSandstone</defName>
    <label>quarry sandstone chunks</label>
    <description>Dig out sandstone chunks from the quarry pit.</description>
    <jobString>Quarrying sandstone.</jobString>
    <workAmount>4000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Mining</workSkill>
    <skillRequirements>
      <Mining>3</Mining>
    </skillRequirements>
    <effectWorking>CutStone</effectWorking>
    <soundWorking>Recipe_MakeStoneBlocks</soundWorking>
    <ingredients />
    <fixedIngredientFilter />
    <products>
      <ChunkSandstone>1</ChunkSandstone>
    </products>
    <recipeUsers>
      <li>Building_QuarrySmall</li>
      <li>Building_QuarryMedium</li>
      <li>Building_QuarryLarge</li>
    </recipeUsers>
  </RecipeDef>

