<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationFindMod">
    <mods>
      <li>Save Our Ship 2</li>
    </mods>
    <match Class="PatchOperationSequence">
      <operations>
        <!-- Add DecompressionResistance and HypoxiaResistance to all standard Android Tiers -->
        <li Class="PatchOperationAdd">
          <xpath>Defs/AlienRace.ThingDef_AlienRace[
              defName="Android1Tier" or 
              defName="Android2Tier" or 
              defName="Android3Tier" or 
              defName="Android4Tier" or 
              defName="Android5Tier"
          ]/statBases</xpath>
          <value>
            <DecompressionResistance>1</DecompressionResistance>
            <HypoxiaResistance>1</HypoxiaResistance>
          </value>
        </li>
      </operations>
    </match>
  </Operation>
</Patch>
